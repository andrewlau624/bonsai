{
  "name": "bonsai",
  "version": "0.1.2",
  "description": "A worktree-aware terminal: repos → branches → tabs, with .env files carried into every git worktree.",
  "author": "Andrew Lau",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "node scripts/postinstall.mjs",
    "gen:icon": "node scripts/gen-icon.mjs",
    "dist": "npm run gen:icon && npm run build && electron-builder",
    "dist:mac": "npm run gen:icon && npm run build && electron-builder --mac",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.10",
    "electron-store": "^8.2.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "node-pty": "^1.0.0",
    "react-markdown": "^9.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vite-plugin-electron": "^0.28.7",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "app.pacific.bonsai",
    "productName": "Bonsai",
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}
